{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Lab Inventory Server",
      "type": "shell",
      "command": "node",
      "args": ["backend/server.js"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Lab Inventory.*running.*",
          "endsPattern": ".*exit.*"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "problemMatcher": []
    }
  ]
}
